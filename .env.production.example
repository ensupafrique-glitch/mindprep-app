# MindPrep — Variables d'environnement attendues côté Vercel (Production)
# ----------------------------------------------------------------------
# Ce fichier liste les variables à saisir dans :
#   Vercel → Project → Settings → Environment Variables → Production
#
# Règles :
#   - NE JAMAIS committer un fichier rempli (ce .example reste vide).
#   - Marquer "Sensitive" toute variable secrète dans l'UI Vercel.
#   - Utiliser des clés DIFFÉRENTES entre Production / Preview / Development.
#   - Chaque variable Sensitive ne doit JAMAIS être lue par un fichier
#     servi côté front (index.html, app.js, core/**/*.js).
#
# Voir docs/15-securite-migration.md pour l'audit complet.


# === URLs publiques ===
# Domaine cible final (après bascule DNS).
MINDPREP_PUBLIC_URL=https://app.mindprep.ai
# URL de fallback (GitHub Pages), conservée tant que la migration
# n'est pas validée à 100%.
MINDPREP_FALLBACK_URL=https://ensupafrique-glitch.github.io/mindprep-app
# URL backend (API serverless / edge functions). À adapter selon archi.
MINDPREP_BACKEND_URL=https://app.mindprep.ai/api


# === Supabase ===
# url + anonKey sont publiques (servies au navigateur).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role : SECRÈTE — jamais côté front, uniquement edge functions.
SUPABASE_SERVICE_ROLE_KEY=


# === IA — OpenAI ===
# SECRÈTE. Toujours via proxy serveur, jamais en direct depuis le browser.
OPENAI_API_KEY=
OPENAI_ORG_ID=


# === IA — Anthropic / Claude ===
# SECRÈTE.
ANTHROPIC_API_KEY=


# === PayDunya (Sénégal / Afrique de l'Ouest) ===
# Mode "test" tant que la migration n'est pas live.
PAYDUNYA_MODE=test
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_PUBLIC_KEY=
# Webhook : à laisser pointer sur l'ancien domaine tant que la phase B
# de la checklist n'est pas validée. Mettre à jour APRÈS bascule DNS.
PAYDUNYA_WEBHOOK_URL=https://app.mindprep.ai/api/webhooks/paydunya


# === Stripe (international) ===
# publishable peut vivre côté front, secret JAMAIS.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# === PayPal ===
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=


# === Wave Business ===
WAVE_BUSINESS_API_KEY=
WAVE_BUSINESS_MERCHANT_ID=
WAVE_BUSINESS_WEBHOOK_SECRET=
WAVE_BUSINESS_BASE_URL=https://api.wave.com


# === Observabilité (optionnel) ===
# Si Sentry / logs externes utilisés.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production


# === Feature flags (optionnel) ===
# Permet d'activer/désactiver des fonctionnalités sans redeploy.
MINDPREP_FEATURE_PREMIUM=true
MINDPREP_FEATURE_GUEST_MODE=true
