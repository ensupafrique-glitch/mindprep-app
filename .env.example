# MindPrep — variables d'environnement (placeholders)
# Copie ce fichier vers `.env` et remplis chaque ligne avec tes vraies clés
# marchandes. NE COMMIT JAMAIS le fichier `.env` rempli (il est ignoré par
# défaut). Toutes les clés "secret" doivent rester côté serveur.

# === PayDunya (Sénégal / Afrique de l'Ouest — passerelle principale) ===
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test
PAYDUNYA_WEBHOOK_URL=

# === Stripe (international, EUR/USD) ===
# La publishable key est exposable côté front, la secret key NE DOIT JAMAIS l'être.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === PayPal (international, EUR/USD) ===
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

# === Wave Business (intégration directe à venir, sans PayDunya) ===
WAVE_BUSINESS_API_KEY=
WAVE_BUSINESS_MERCHANT_ID=
WAVE_BUSINESS_WEBHOOK_SECRET=
WAVE_BUSINESS_BASE_URL=https://api.wave.com
